---
// src/pages/index.astro
import modelsData from '../lib/models-data.json' with { type: 'json' };
import type { ModelStats } from '../types/index.ts';
import SpeedInsights from "@vercel/speed-insights/astro"

const MODELS_DATA = modelsData as Record<string, ModelStats>;
const MODELS = Object.entries(MODELS_DATA).map(([id, m]) => ({
  id,
  ...m
}));

const grouped = MODELS.reduce((acc, m) => {
  if (!acc[m.provider]) acc[m.provider] = []
  acc[m.provider].push(m)
  return acc
}, {} as Record<string, typeof MODELS>)

const PURPOSES = [
  { id: 'coding',           label: 'Coding',           desc: 'Logic & Syntax',   icon: '⌨️' },
  { id: 'writing',          label: 'Writing',          desc: 'Creative & Copy',  icon: '✍️' },
  { id: 'research',         label: 'Research',         desc: 'Deep Analysis',    icon: '🔬' },
  { id: 'math',             label: 'Logic',            desc: 'Math & Reasoning', icon: '🧮' },
  { id: 'chat',             label: 'Chat',             desc: 'General Assistant', icon: '💬' },
  { id: 'data_analysis',    label: 'Data',             desc: 'Insights & Stats',  icon: '📊' },
  { id: 'image_generation', label: 'Image',            desc: 'Visual Creation',   icon: '🎨' },
  { id: 'video_generation', label: 'Video',            desc: 'Motion Content',   icon: '🎬' },
]

const PROVIDER_COLORS: Record<string, string> = {
  OpenAI:     'text-[#10b981] bg-[#10b98110] border-[#10b98120]',
  Anthropic:  'text-[#f97316] bg-[#f9731610] border-[#f9731620]',
  Google:     'text-[#3b82f6] bg-[#3b82f610] border-[#3b82f620]',
  Meta:       'text-[#6366f1] bg-[#6366f110] border-[#6366f120]',
  DeepSeek:   'text-[#06b6d4] bg-[#06b6d410] border-[#06b6d420]',
  xAI:        'text-[#a855f7] bg-[#a855f710] border-[#a855f720]',
  Mistral:    'text-[#f43f5e] bg-[#f43f5e10] border-[#f43f5e20]',
  'Mistral AI': 'text-[#f43f5e] bg-[#f43f5e10] border-[#f43f5e20]',
  Alibaba:    'text-[#eab308] bg-[#eab30810] border-[#eab30820]',
}
---

<!DOCTYPE html>
<html lang="en" class="bg-[#080c14] scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ModelMatch — Find the right AI for your task.</title>
  <link rel="icon" type="image/png" href="/icon.png" />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{
      "@type": "Question",
      "name": "What is ModelMatch?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ModelMatch is a free AI model comparison tool that helps you find the best model for your specific task. Select two models, pick your purpose, and get an instant side-by-side performance analysis."
      }
    }, {
      "@type": "Question",
      "name": "How are comparisons generated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Each comparison is generated by an AI that analyzes benchmark data, model specifications, and known performance characteristics across different tasks. Results are cached for 24 hours to improve speed."
      }
    }, {
      "@type": "Question",
      "name": "Is ModelMatch free to use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, ModelMatch is completely free. There are no usage limits, no sign-ups required, and no hidden fees. Just select your models and compare."
      }
    }, {
      "@type": "Question",
      "name": "Which models are included?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We cover models from OpenAI, Anthropic, Google, Meta, DeepSeek, Mistral, xAI, Cohere, Microsoft, Amazon, Alibaba, and more. We regularly add new models as they are released."
      }
    }, {
      "@type": "Question",
      "name": "What do the benchmark scores mean?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Scores (purpose fit, speed, accuracy, cost efficiency) are relative percentages comparing the two models for your selected purpose. Higher is better for each metric."
      }
    }]
  }
  </script>
  <SpeedInsights />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', system-ui, sans-serif; -webkit-font-smoothing: antialiased; color: #f0f4ff; }
    .mono { font-family: 'JetBrains Mono', monospace; }
    
    @keyframes barGrow { from { width: 0%; } }
    .animate-bar { animation: barGrow 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    
    @keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    .animate-fade-up { animation: fadeUp 0.4s ease-out forwards; }
    
    @keyframes spin { to { transform: rotate(360deg); } }
    .animate-spin { animation: spin 0.8s linear infinite; }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #080c14; }
    ::-webkit-scrollbar-thumb { background: #1e2d40; border-radius: 3px; }

    .card { background: #0f1521; border: 1px solid #1e2d40; border-radius: 8px; transition: border-color 150ms ease; }
    .card:hover { border-color: #2d3f55; }
    .label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; }
  </style>
</head>

<body class="min-h-screen flex flex-col">
  
  <!-- NAVBAR -->
  <nav class="sticky top-0 z-50 bg-[#080c14]/80 backdrop-blur-md border-b border-[#1e2d40]">
    <div class="max-w-[680px] mx-auto px-6 h-14 flex items-center justify-between">
      <div class="flex items-center gap-2 cursor-pointer" onclick="window.location.href='/'">
        <img src="/icon.png" alt="ModelMatch" class="h-7 w-auto" />
        <div class="font-bold text-lg tracking-tight">
          <span class="text-white">Model</span><span class="text-[#4f7eff]">Match</span>
        </div>
      </div>
      <div class="px-2.5 py-1 rounded-full bg-[#4f7eff10] border border-[#4f7eff20] text-[10px] font-semibold text-[#4f7eff] tracking-wide uppercase">
        Free · abdullah
      </div>
    </div>
  </nav>

  <main class="flex-1 max-w-[680px] mx-auto w-full px-4 sm:px-6 py-8 sm:py-12">
    
    <!-- HOME VIEW -->
    <div id="home-view" class="space-y-12">
      <!-- HERO -->
      <header class="text-center space-y-6 pt-8">
      
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#1e2d40] border border-[#2d3f55] text-[11px] font-medium text-slate-300">
          <span class="w-1.5 h-1.5 rounded-full bg-[#4f7eff] animate-pulse"></span>
          ⚡ AI-Powered Comparison
        </div>
        <h1 class="text-4xl sm:text-[56px] font-bold leading-[1.1] tracking-tight text-white">
          Find the right AI<br/>
          <span class="text-[#4f7eff]">for your task.</span>
        </h1>
        <p class="text-lg text-[#64748b] max-w-md mx-auto leading-relaxed">
          Select two models, pick your purpose, and get instant performance results.
        </p>
      </header>

      <!-- COMPARE FORM -->
      <section class="card p-5 sm:p-6 space-y-5 sm:space-y-6">
        
        <!-- Model Selection -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="space-y-2">
            <label class="label">Model A</label>
            <div class="relative" data-dropdown="1">
              <button class="dropdown-trigger w-full h-11 px-4 rounded-lg bg-[#080c14] border border-[#1e2d40] text-sm text-left flex items-center justify-between focus:outline-none focus:border-[#4f7eff] transition-all">
                <span class="dropdown-placeholder text-[#64748b]">Select model...</span>
                <span class="dropdown-selected text-white hidden"></span>
                <svg class="w-4 h-4 text-[#64748b] shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="dropdown-panel hidden absolute z-50 mt-1 w-full rounded-lg bg-[#0f1521] border border-[#1e2d40] shadow-xl overflow-hidden">
                <div class="p-2 border-b border-[#1e2d40]">
                  <input type="text" class="dropdown-search w-full h-9 px-3 rounded-md bg-[#080c14] border border-[#1e2d40] text-sm text-[#f0f4ff] placeholder:text-[#64748b] focus:outline-none focus:border-[#4f7eff] outline-none" placeholder="Search models..." />
                </div>
                <div class="dropdown-list overflow-y-auto max-h-60"></div>
              </div>
            </div>
            <div id="badge1" class="hidden text-[10px] font-bold uppercase px-2 py-0.5 rounded border inline-block"></div>
          </div>

          <div class="space-y-2">
            <label class="label">Model B</label>
            <div class="relative" data-dropdown="2">
              <button class="dropdown-trigger w-full h-11 px-4 rounded-lg bg-[#080c14] border border-[#1e2d40] text-sm text-left flex items-center justify-between focus:outline-none focus:border-[#4f7eff] transition-all">
                <span class="dropdown-placeholder text-[#64748b]">Select model...</span>
                <span class="dropdown-selected text-white hidden"></span>
                <svg class="w-4 h-4 text-[#64748b] shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="dropdown-panel hidden absolute z-50 mt-1 w-full rounded-lg bg-[#0f1521] border border-[#1e2d40] shadow-xl overflow-hidden">
                <div class="p-2 border-b border-[#1e2d40]">
                  <input type="text" class="dropdown-search w-full h-9 px-3 rounded-md bg-[#080c14] border border-[#1e2d40] text-sm text-[#f0f4ff] placeholder:text-[#64748b] focus:outline-none focus:border-[#4f7eff] outline-none" placeholder="Search models..." />
                </div>
                <div class="dropdown-list overflow-y-auto max-h-60"></div>
              </div>
            </div>
            <div id="badge2" class="hidden text-[10px] font-bold uppercase px-2 py-0.5 rounded border inline-block"></div>
          </div>
        </div>

        <!-- Purpose Grid -->
        <div class="space-y-3">
          <label class="label">Purpose</label>
          <div class="grid grid-cols-2 gap-2" id="purposeGrid">
            {PURPOSES.map(p => (
              <button data-purpose={p.id} class="purpose-btn group flex flex-col gap-1 p-3 rounded-lg border border-[#1e2d40] bg-transparent text-left transition-all hover:border-[#2d3f55]">
                <div class="text-lg">{p.icon}</div>
                <div class="text-sm font-semibold text-slate-200">{p.label}</div>
                <div class="text-[10px] text-[#64748b] leading-tight">{p.desc}</div>
              </button>
            ))}
          </div>
        </div>

        <!-- Compare Button -->
        <button id="compareBtn" disabled class="w-full h-12 rounded-lg bg-[#1e2d40] text-[#334155] font-semibold text-sm transition-all cursor-not-allowed">
          <span id="btnText">Compare Models</span>
        </button>

      </section>
    </div>

    <!-- LOADING STATE -->
    <div id="loading" class="hidden flex flex-col items-center justify-center py-24 space-y-4">
      <svg class="animate-spin w-8 h-8 text-[#4f7eff]" viewBox="0 0 24 24" fill="none">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <span class="text-sm font-medium text-[#64748b]">Analyzing models...</span>
    </div>

    <!-- ERROR STATE -->
    <div id="error" class="hidden p-4 rounded-lg border border-red-500/20 bg-red-500/5 text-center text-sm text-red-400"></div>

    <!-- RESULTS VIEW -->
    <div id="results-view" class="hidden space-y-10 animate-fade-up">
      
      <div class="flex justify-between items-center pb-4 border-b border-[#1e2d40]">
        <div class="flex flex-col gap-1">
          <h2 class="label">Analysis Report</h2>
          <div id="report-title" class="text-sm font-semibold text-white"></div>
        </div>
        <button id="resetBtn" class="text-[11px] font-bold uppercase tracking-widest text-[#4f7eff] hover:text-white transition-colors">New Comparison</button>
      </div>

      <div id="result-content" class="space-y-8">
        <!-- Rendered via JS -->
      </div>

    </div>

  </main>

  <!-- FAQ -->
  <section class="max-w-[680px] mx-auto w-full px-6 pb-12">
    <div class="space-y-6">
      <div class="text-center">
        <h2 class="text-xl sm:text-2xl font-bold text-white">Frequently Asked Questions</h2>
        <p class="text-sm text-[#64748b] mt-2">Everything you need to know about ModelMatch.</p>
      </div>
      <div class="space-y-3">
        <details class="card p-5 group open:border-[#4f7eff40]">
          <summary class="flex items-center justify-between cursor-pointer text-sm font-semibold text-[#f0f4ff] list-none">
            What is ModelMatch?
            <svg class="w-4 h-4 text-[#64748b] group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-4 text-sm text-[#94a3b8] leading-relaxed">ModelMatch is a free AI model comparison tool that helps you find the best model for your specific task. Select two models, pick your purpose, and get an instant side-by-side performance analysis.</p>
        </details>
        <details class="card p-5 group open:border-[#4f7eff40]">
          <summary class="flex items-center justify-between cursor-pointer text-sm font-semibold text-[#f0f4ff] list-none">
            How are comparisons generated?
            <svg class="w-4 h-4 text-[#64748b] group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-4 text-sm text-[#94a3b8] leading-relaxed">Each comparison is generated by an AI that analyzes benchmark data, model specifications, and known performance characteristics across different tasks. Results are cached for 24 hours to improve speed.</p>
        </details>
        <details class="card p-5 group open:border-[#4f7eff40]">
          <summary class="flex items-center justify-between cursor-pointer text-sm font-semibold text-[#f0f4ff] list-none">
            Is ModelMatch free to use?
            <svg class="w-4 h-4 text-[#64748b] group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-4 text-sm text-[#94a3b8] leading-relaxed">Yes, ModelMatch is completely free. There are no usage limits, no sign-ups required, and no hidden fees. Just select your models and compare.</p>
        </details>
        <details class="card p-5 group open:border-[#4f7eff40]">
          <summary class="flex items-center justify-between cursor-pointer text-sm font-semibold text-[#f0f4ff] list-none">
            Which models are included?
            <svg class="w-4 h-4 text-[#64748b] group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-4 text-sm text-[#94a3b8] leading-relaxed">We cover models from OpenAI, Anthropic, Google, Meta, DeepSeek, Mistral, xAI, Cohere, Microsoft, Amazon, Alibaba, and more. We regularly add new models as they are released.</p>
        </details>
        <details class="card p-5 group open:border-[#4f7eff40]">
          <summary class="flex items-center justify-between cursor-pointer text-sm font-semibold text-[#f0f4ff] list-none">
            What do the benchmark scores mean?
            <svg class="w-4 h-4 text-[#64748b] group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-4 text-sm text-[#94a3b8] leading-relaxed">Scores (purpose fit, speed, accuracy, cost efficiency) are relative percentages comparing the two models for your selected purpose. Higher is better for each metric.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="py-12 border-t border-[#1e2d40] text-center space-y-4">
    <div class="flex items-center justify-center gap-6 text-[10px] font-bold uppercase tracking-widest">
      <a href="/about" class="text-[#334155] hover:text-[#4f7eff] transition-colors">About</a>
      <a href="/privacy" class="text-[#334155] hover:text-[#4f7eff] transition-colors">Privacy</a>
      <a href="/terms" class="text-[#334155] hover:text-[#4f7eff] transition-colors">Terms</a>
      <a href="/contact" class="text-[#334155] hover:text-[#4f7eff] transition-colors">Contact</a>
    </div>
    <div class="text-[11px] font-medium text-[#334155] uppercase tracking-widest">
      abdullah systems
    </div>
    <div class="text-[10px] text-[#334155]">
      © 2026 ModelMatch. All rights reserved.
    </div>
  </footer>

  <script define:vars={{ MODELS, PURPOSES, PROVIDER_COLORS }}>
    let s1 = '', s2 = '', sp = '';

    const b1 = document.getElementById('badge1');
    const b2 = document.getElementById('badge2');
    const btn = document.getElementById('compareBtn');
    const homeView = document.getElementById('home-view');
    const loading = document.getElementById('loading');
    const error = document.getElementById('error');
    const resultsView = document.getElementById('results-view');
    const resultContent = document.getElementById('result-content');
    const resetBtn = document.getElementById('resetBtn');

    const MODEL_OPTIONS = MODELS.map(m => ({ id: m.id, name: m.name, provider: m.provider }));

    function selectModel(dropdownIdx, modelId) {
      const model = MODEL_OPTIONS.find(m => m.id === modelId);
      if (!model) return;
      const container = document.querySelector(`[data-dropdown="${dropdownIdx}"]`);
      const placeholder = container.querySelector('.dropdown-placeholder');
      const selected = container.querySelector('.dropdown-selected');
      placeholder.classList.add('hidden');
      selected.classList.remove('hidden');
      selected.textContent = model.name;
      const panel = container.querySelector('.dropdown-panel');
      panel.classList.add('hidden');
      if (dropdownIdx === 1) { s1 = modelId; updateBadge(b1, modelId); }
      else { s2 = modelId; updateBadge(b2, modelId); }
      updateBtn();
    }

    function renderDropdownList(container, filter = '') {
      const list = container.querySelector('.dropdown-list');
      const idx = container.dataset.dropdown;
      const lower = filter.toLowerCase();
      const filtered = MODEL_OPTIONS.filter(m => m.name.toLowerCase().includes(lower) || m.provider.toLowerCase().includes(lower));
      const grouped = filtered.reduce((acc, m) => {
        if (!acc[m.provider]) acc[m.provider] = [];
        acc[m.provider].push(m);
        return acc;
      }, {});
      let html = '';
      const entries = Object.entries(grouped);
      if (entries.length === 0) {
        html = '<div class="px-3 py-8 text-center text-[11px] text-[#64748b]">No models found</div>';
      } else {
        entries.forEach(([provider, models]) => {
          html += `<div class="px-3 pt-3 pb-1 text-[10px] font-bold uppercase tracking-wider text-[#64748b]">${provider}</div>`;
          models.forEach(m => {
            html += `<button class="dropdown-item w-full text-left px-3 py-2 text-sm text-[#f0f4ff] hover:bg-[#1e2d40] transition-colors" data-id="${m.id}">${m.name}</button>`;
          });
        });
      }
      list.innerHTML = html;
      list.querySelectorAll('.dropdown-item').forEach(el => {
        el.addEventListener('click', () => selectModel(parseInt(idx), el.dataset.id));
      });
    }

    document.querySelectorAll('[data-dropdown]').forEach(container => {
      const idx = container.dataset.dropdown;
      const trigger = container.querySelector('.dropdown-trigger');
      const panel = container.querySelector('.dropdown-panel');
      const search = container.querySelector('.dropdown-search');

      renderDropdownList(container);

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !panel.classList.contains('hidden');
        document.querySelectorAll('.dropdown-panel').forEach(p => p.classList.add('hidden'));
        if (!isOpen) {
          panel.classList.remove('hidden');
          search.value = '';
          renderDropdownList(container);
          setTimeout(() => search.focus(), 50);
        }
      });

      search.addEventListener('input', () => renderDropdownList(container, search.value));

      search.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') panel.classList.add('hidden');
      });
    });

    document.addEventListener('click', () => {
      document.querySelectorAll('.dropdown-panel').forEach(p => p.classList.add('hidden'));
    });

    function updateBadge(badge, modelId) {
      const model = MODEL_OPTIONS.find(m => m.id === modelId);
      if (!model) { badge.classList.add('hidden'); return; }
      const colorCls = PROVIDER_COLORS[model.provider] || 'text-[#64748b] bg-[#1e2d40] border-[#2d3f55]';
      badge.className = `text-[10px] font-bold uppercase px-2 py-0.5 rounded border inline-block ${colorCls}`;
      badge.textContent = model.provider;
      badge.classList.remove('hidden');
    }

    function updateBtn() {
      const ready = s1 && s2 && sp && s1 !== s2;
      btn.disabled = !ready;
      if (ready) {
        btn.className = 'w-full h-12 rounded-lg bg-[#4f7eff] text-white font-semibold text-sm transition-all cursor-pointer hover:bg-[#3d6de0] shadow-lg shadow-[#4f7eff20]';
      } else {
        btn.className = 'w-full h-12 rounded-lg bg-[#1e2d40] text-[#334155] font-semibold text-sm transition-all cursor-not-allowed';
      }
    }

    document.querySelectorAll('.purpose-btn').forEach(b => {
      b.addEventListener('click', () => {
        sp = b.dataset.purpose;
        document.querySelectorAll('.purpose-btn').forEach(btn => {
          btn.classList.remove('border-[#4f7eff]', 'bg-[#4f7eff10]');
          btn.classList.add('border-[#1e2d40]', 'bg-transparent');
        });
        b.classList.add('border-[#4f7eff]', 'bg-[#4f7eff10]');
        b.classList.remove('border-[#1e2d40]', 'bg-transparent');
        updateBtn();
      });
    });

    resetBtn.addEventListener('click', () => {
      resultsView.classList.add('hidden');
      homeView.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    btn.addEventListener('click', async () => {
      homeView.classList.add('hidden');
      loading.classList.remove('hidden');
      error.classList.add('hidden');
      resultsView.classList.add('hidden');
      
      try {
        const res = await fetch('/api/compare', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ model1: s1, model2: s2, purpose: sp })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Comparison failed');
        render(data);
      } catch (err) {
        error.textContent = err.message;
        error.classList.remove('hidden');
        homeView.classList.remove('hidden');
      } finally {
        loading.classList.add('hidden');
      }
    });

    function render(data) {
      const { winner, reason, model1, model2, verdict, cached } = data;
      const isM1Win = winner === model1.name;
      const purposeLabel = PURPOSES.find(p => p.id === sp)?.label || sp;

      document.getElementById('report-title').textContent = `${model1.name} vs ${model2.name} • ${purposeLabel}`;

      resultContent.innerHTML = `
        <!-- WINNER CARD -->
        <div class="card p-6 sm:p-8 border-l-[4px] border-l-[#4f7eff] relative overflow-hidden">
          <div class="absolute top-0 right-0 p-3">
             ${cached ? '<span class="text-[9px] font-bold uppercase text-[#4f7eff] px-2 py-0.5 rounded bg-[#4f7eff10] border border-[#4f7eff20]">cached</span>' : ''}
          </div>
          <div class="flex flex-col sm:flex-row items-start gap-4 sm:gap-6">
            <div class="w-12 h-12 sm:w-16 sm:h-16 rounded-2xl bg-[#4f7eff10] border border-[#4f7eff20] flex items-center justify-center text-2xl sm:text-3xl shrink-0">🏆</div>
            <div class="space-y-2">
              <span class="label">Primary Choice</span>
              <h3 class="text-2xl sm:text-4xl font-bold text-white tracking-tight">${winner}</h3>
              <p class="text-[15px] text-[#64748b] leading-relaxed max-w-md">${reason}</p>
            </div>
          </div>
        </div>

        <!-- PERFORMANCE CARD -->
        <div class="card p-6 sm:p-8 space-y-8">
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
            <h4 class="label">Performance Benchmarks</h4>
            <div class="flex gap-4">
               <div class="flex items-center gap-2 text-[10px] font-bold uppercase text-slate-400">
                  <div class="w-2 h-2 rounded-full bg-[#4f7eff]"></div> ${model1.name}
               </div>
               <div class="flex items-center gap-2 text-[10px] font-bold uppercase text-slate-400">
                  <div class="w-2 h-2 rounded-full bg-[#f97316]"></div> ${model2.name}
               </div>
            </div>
          </div>
          
          <div class="space-y-8">
            ${['purpose_fit', 'speed', 'accuracy', 'cost_efficiency'].map(key => {
              const v1 = model1.scores[key], v2 = model2.scores[key];
              const m1Winner = v1 >= v2;
              return `
                <div class="space-y-3">
                  <div class="flex justify-between items-end">
                    <span class="text-xs font-bold text-[#f0f4ff] capitalize tracking-wide">${key.replace('_', ' ')}</span>
                    <div class="flex gap-3 sm:gap-6">
                      <div class="flex flex-col items-end">
                        <span class="mono text-[11px] ${m1Winner ? 'text-[#4f7eff]' : 'text-[#334155]'}">${v1}%</span>
                      </div>
                      <div class="flex flex-col items-end">
                        <span class="mono text-[11px] ${!m1Winner ? 'text-[#f97316]' : 'text-[#334155]'}">${v2}%</span>
                      </div>
                    </div>
                  </div>
                  
                  <!-- Stacked Bar Logic -->
                  <div class="grid grid-cols-2 gap-4 h-2">
                    <div class="relative bg-[#080c14] rounded-full overflow-hidden">
                       <div class="animate-bar absolute top-0 left-0 h-full bg-[#4f7eff] rounded-full ${m1Winner ? 'shadow-[0_0_12px_#4f7eff40]' : 'opacity-30'}" style="width: ${v1}%"></div>
                    </div>
                    <div class="relative bg-[#080c14] rounded-full overflow-hidden">
                       <div class="animate-bar absolute top-0 left-0 h-full bg-[#f97316] rounded-full ${!m1Winner ? 'shadow-[0_0_12px_#f9731640]' : 'opacity-30'}" style="width: ${v2}%"></div>
                    </div>
                  </div>
                </div>
              `;
            }).join('')}
          </div>
        </div>

        <!-- STATS CARD -->
        <div class="card p-6 sm:p-8 space-y-6">
          <h4 class="label">Technical Specification</h4>
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-[#1e2d40]">
                  <th class="py-4 font-medium text-[#64748b] w-1/3 text-xs">Architectural Detail</th>
                  <th class="py-4 font-bold text-white uppercase text-[10px] tracking-widest">${model1.name} ${isM1Win ? '✓' : ''}</th>
                  <th class="py-4 font-bold text-white uppercase text-[10px] tracking-widest">${model2.name} ${!isM1Win ? '✓' : ''}</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-[#1e2d40]/40">
                ${['params', 'context_window', 'embedding_dims', 'latest_version', 'pricing'].map(key => `
                  <tr>
                    <td class="py-4 text-[#64748b] text-[12px] font-medium capitalize">${key.replace('_', ' ')}</td>
                    <td class="py-4 mono text-[11px] ${isM1Win ? 'text-white' : 'text-slate-400'} pr-4">${model1[key]}</td>
                    <td class="py-4 mono text-[11px] ${!isM1Win ? 'text-white' : 'text-slate-400'}">${model2[key]}</td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        </div>

        <!-- VERDICT CARD -->
        <div class="card p-6 sm:p-8 bg-gradient-to-br from-[#0f1521] to-[#161d2b] border-[#2d3f55]">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-1.5 h-6 bg-[#4f7eff] rounded-full"></div>
            <h4 class="label text-white">AI Comprehensive Verdict</h4>
          </div>
          <p class="text-[15px] text-[#cbd5e1] leading-[1.8] italic font-medium">"${verdict}"</p>
        </div>
      `;

      resultsView.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  </script>
</body>
</html>
