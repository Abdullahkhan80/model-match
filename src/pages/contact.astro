---
const sent = Astro.url.searchParams.get('sent')
---
<!DOCTYPE html>
<html lang="en" class="bg-[#080c14] scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Us — ModelMatch</title>
  <link rel="icon" type="image/png" href="/icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', system-ui, sans-serif; -webkit-font-smoothing: antialiased; color: #f0f4ff; }
    .mono { font-family: 'JetBrains Mono', monospace; }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #080c14; }
    ::-webkit-scrollbar-thumb { background: #1e2d40; border-radius: 3px; }
    .card { background: #0f1521; border: 1px solid #1e2d40; border-radius: 8px; }
    .card:hover { border-color: #2d3f55; }
    .label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; }
  </style>
</head>
<body class="min-h-screen flex flex-col">
  <nav class="sticky top-0 z-50 bg-[#080c14]/80 backdrop-blur-md border-b border-[#1e2d40]">
    <div class="max-w-[680px] mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
      <div class="flex items-center gap-2 cursor-pointer" onclick="window.location.href='/'">
        <img src="/icon.png" alt="ModelMatch" class="h-7 w-auto" />
        <div class="font-bold text-lg tracking-tight">
          <span class="text-white">Model</span><span class="text-[#4f7eff]">Match</span>
        </div>
      </div>
      <a href="/" class="text-[11px] font-bold uppercase tracking-widest text-[#4f7eff] hover:text-white transition-colors">Back</a>
    </div>
  </nav>

  <main class="flex-1 max-w-[680px] mx-auto w-full px-4 sm:px-6 py-12">
    <div class="space-y-8">
      <div class="text-center">
        <h1 class="text-3xl sm:text-4xl font-bold text-white">Contact Us</h1>
        <p class="text-sm text-[#64748b] mt-2">Get in touch with the ModelMatch team.</p>
      </div>

      {sent && (
        <div class="p-4 rounded-lg border border-[#10b98120] bg-[#10b98110] text-center text-sm text-[#10b981]">Message sent successfully! Check your inbox for a confirmation email.</div>
      )}

      <div class="card p-6 sm:p-8">
        <form action="https://formsubmit.co/hello@abdullahsystems.com" method="POST" class="space-y-5">
          <input type="hidden" name="_subject" value="ModelMatch Contact Form" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="/contact?sent=1" />
          <input type="hidden" name="_autoresponse" value="Thank you for reaching out! We'll get back to you within 7-10 days." />
          <div class="space-y-2">
            <label class="label">Name</label>
            <input type="text" name="name" required class="w-full h-11 px-4 rounded-lg bg-[#080c14] border border-[#1e2d40] text-sm text-[#f0f4ff] placeholder:text-[#64748b] focus:outline-none focus:border-[#4f7eff] transition-all" placeholder="Your name" />
          </div>
          <div class="space-y-2">
            <label class="label">Email</label>
            <input type="email" name="email" required class="w-full h-11 px-4 rounded-lg bg-[#080c14] border border-[#1e2d40] text-sm text-[#f0f4ff] placeholder:text-[#64748b] focus:outline-none focus:border-[#4f7eff] transition-all" placeholder="your@email.com" />
          </div>
          <div class="space-y-2">
            <label class="label">Message</label>
            <textarea name="message" rows="5" required class="w-full px-4 py-3 rounded-lg bg-[#080c14] border border-[#1e2d40] text-sm text-[#f0f4ff] placeholder:text-[#64748b] focus:outline-none focus:border-[#4f7eff] transition-all resize-none" placeholder="How can we help?"></textarea>
          </div>
          <button type="submit" class="w-full h-12 rounded-lg bg-[#4f7eff] text-white font-semibold text-sm transition-all cursor-pointer hover:bg-[#3d6de0] shadow-lg shadow-[#4f7eff20]">Send Message</button>
        </form>
        <p class="text-center text-[10px] text-[#334155] mt-4">We generally respond within 7-10 days.</p>
      </div>

      <div class="card p-6 sm:p-8 space-y-4">
        <h2 class="label">Other Ways to Reach Us</h2>
        <div class="space-y-3 text-sm text-[#94a3b8]">
          <p><span class="text-[#64748b] font-medium">LinkedIn:</span> <a href="https://www.linkedin.com/in/abdullah-7a90632b8/" class="text-[#4f7eff] hover:underline" target="_blank" rel="noopener">Abdullah on LinkedIn</a></p>
        </div>
      </div>
    </div>
  </main>

  <footer class="py-12 border-t border-[#1e2d40] text-center space-y-2">
    <div class="text-[11px] font-medium text-[#334155] uppercase tracking-widest">
      abdullah systems
    </div>
    <div class="text-[10px] text-[#334155]">
      © 2026 ModelMatch. All rights reserved.
    </div>
  </footer>
</body>
</html>
